# =============================================================================
# YushaGPT Bot — Environment Variables
# Copy file ini jadi .env dan isi nilainya
# cp .env.example .env
# =============================================================================

# Telegram Bot Token dari @BotFather
# Cara dapat: buka @BotFather di Telegram → /newbot → ikuti instruksi
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Secret key untuk session (isi dengan string random panjang)
# Generate: openssl rand -base64 32
SESSION_SECRET=ganti_dengan_string_random_panjang_minimal_32_karakter

# Environment (development / production)
NODE_ENV=production

# Port server (default 8080)
PORT=8080
